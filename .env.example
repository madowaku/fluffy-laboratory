# Google AI Studio / Gemini API key
# SECURITY WARNING: DO NOT prefix this with NEXT_PUBLIC_.
# This key must remain on the server and should never be exposed to the browser.
# Keep this key in `.env.local` only, and never commit it to git.
GOOGLE_GENERATIVE_AI_API_KEY=

# Use "mock" until AI integration is ready, or "google" to use Gemini
LLM_PROVIDER=mock
